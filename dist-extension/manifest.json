{
  "manifest_version": 3,
  "name": "Adrian Transcript Scraper",
  "version": "1.0.0",
  "description": "Extract transcripts from Adrian Cantrill's courses",
  "permissions": [
    "downloads",
    "webRequest",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://learn.cantrill.io/*",
    "https://*.hotmart.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.ts-loader-g5NqrE94.js"
      ],
      "matches": [
        "https://learn.cantrill.io/*"
      ]
    }
  ],
  "action": {
    "default_title": "Adrian Scraper"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://learn.cantrill.io/*"
      ],
      "resources": [
        "assets/content.ts-BsxNEaDN.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
