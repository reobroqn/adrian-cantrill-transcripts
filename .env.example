# Adrian Cantrill Teachable Credentials
EMAIL=your_email@example.com
PASSWORD=your_password

# Course ID (can be found in the course URL)
COURSE_ID=1820301

# Processing Configuration
# SESSION takes priority over ALL. If SESSION is set, only that section is processed.
# Set ALL=true to process every lecture in the manifest (only if SESSION is empty).
SESSION=
ALL=true

# Technical Tuning
CONCURRENCY=4
SEEK=true

# Set DIRECT=true to bypass browser video playback and download VTT segments directly from CDN.
DIRECT=true
